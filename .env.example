# Copier en .env et ajuster pour la production : `cp .env.example .env`

# --- Base de données ---
POSTGRES_USER=visiocheck
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=visiocheck
DATABASE_URL=postgres://visiocheck:change-me-in-prod@db:5432/visiocheck

# --- Backend ---
# Origine autorisée pour CORS (URL publique du frontend).
CORS_ORIGIN=http://localhost:4200
# Authentification JWT. Laisser JWT_SECRET vide = auth désactivée (mode ouvert).
# Renseigner un secret fort + un compte admin amorcé pour activer l'auth.
JWT_SECRET=
JWT_EXPIRES_IN=12h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-prod

# --- Frontend ---
BACKEND_URL=http://localhost:3000

# --- WebRTC / TURN (uniquement si transport WebRTC + docker-compose.webrtc.yml) ---
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:localhost:3478
TURN_USERNAME=visiocheck
TURN_PASSWORD=change-me

# --- Service IA ---
# Détection
VC_DETECTOR_MODEL=yolo11n.pt
VC_DETECTOR_CONF=0.35
# VLM (description). Mettre false pour démarrer sans GPU (résumés déterministes).
VC_VLM_ENABLED=true
VC_VLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct-AWQ
