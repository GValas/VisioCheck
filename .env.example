# Copier en .env et ajuster pour la production : `cp .env.example .env`

# --- Base de données ---
POSTGRES_USER=visiocheck
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=visiocheck
DATABASE_URL=postgres://visiocheck:change-me-in-prod@db:5432/visiocheck

# --- Backend ---
# Origine autorisée pour CORS (URL publique du frontend).
CORS_ORIGIN=http://localhost:4200
# Token API partagé. Laisser vide pour désactiver l'auth (déconseillé en prod).
API_TOKEN=

# --- Frontend ---
BACKEND_URL=http://localhost:3000

# --- Service IA ---
# Détection
VC_DETECTOR_MODEL=yolo11n.pt
VC_DETECTOR_CONF=0.35
# VLM (description). Mettre false pour démarrer sans GPU (résumés déterministes).
VC_VLM_ENABLED=true
VC_VLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct-AWQ
